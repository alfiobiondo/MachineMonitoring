{
  "MachineData": {
    "FilePath": "Data/machines.json"
  },
  "Polling": {
    "IntervalSeconds": 3,
    "InitialDelaySeconds": 2
  },
  "Diagnostics": {
    "MaxConcurrency": 3
  },
  "DiagnosticRetry": {
    "MaxRetryAttempts": 2,
    "DelayMilliseconds": 500
  },
  "DiagnosticCache": {
    "Enabled": true,
    "DurationSeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "MachineMonitoring": "Debug"
    }
  }
}